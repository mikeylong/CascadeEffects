      "pattern": "\\bduplicate(?=\\s+safety\\b)",
      "replacement": "dupli-kate",
      "case_sensitive": false,
      "pronunciation_note": "Verb form of duplicate. Avoid noun-like dupli-cut delivery.",
      "source_note": "Therac-25 repair."
    },
    {
