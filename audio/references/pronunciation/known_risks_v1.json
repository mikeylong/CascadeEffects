{
  "schema_version": "1.0",
  "name": "cascade_effects_elevenlabs_known_pronunciation_risks_v1",
  "description": "Curated pronunciation rules for known ElevenLabs risk terms. Captions and locked scripts remain unchanged; local aliases apply only to provider-specific render text.",
  "rules": [
    {
      "id": "live_load_long_i",
      "status": "approved",
      "severity": "required",
      "mode": "local_alias",
      "match_type": "literal",
      "pattern": "live load",
      "replacement": "lyve load",
      "case_sensitive": false,
      "pronunciation_note": "Structural load term. Pronounce live with long-I, rhyming with hive.",
      "source_note": "Hyatt Regency repair."
    },
    {
      "id": "duplicate_safety_verb",
      "status": "approved",
      "severity": "required",
