    "verified_claims": [
      {
        "claim_id": "atrium_walkway_layout",
        "status": "pass",
        "claim": "The Hyatt atrium had suspended walkways at the second, third, and fourth floor levels; the second-floor walkway was directly below and suspended from the fourth-floor walkway, while the third-floor walkway was offset and independently suspended.",
        "basis": [
          "NIST/NBS BSS 143 abstract and summary lines from extracted text around 248-256 and 339-348."
        ]
      },
      {
        "claim_id": "collapse_scope",
        "status": "pass",
        "claim": "The second- and fourth-floor walkways fell to the atrium floor, with the fourth-floor walkway coming to rest on top of the lower walkway.",
        "basis": [
          "NIST/NBS BSS 143 extracted text around 256-259 and 1067-1068."
        ]
      },
      {
        "claim_id": "probable_cause_connection_capacity",
        "status": "pass",
        "claim": "NIST identified insufficient load capacity in the box beam-hanger rod connection at the fourth-floor walkway as the probable failure mechanism.",
        "basis": [
          "NIST/NBS BSS 143 extracted text around 259-263."
        ]
      },
      {
        "claim_id": "rod_revision_doubled_load",
        "status": "pass",
        "claim": "Changing from continuous hanger rods to two sets of rods doubled the load transferred by the fourth-floor box beam-hanger rod connections.",
        "basis": [
          "NIST/NBS BSS 143 extracted text around 268-278 and 439; ASCE article saved at paragraph lines around 1422."
        ]
      },
      {
        "claim_id": "event_and_casualty_public_context",
        "status": "pass",
        "claim": "The collapse occurred during a public event in the atrium; public-facing casualty context may state 114 killed and 216 injured when needed, but marketing copy should avoid sensational framing.",
        "basis": [
          "ASCE saved page line around 1421; NIST/NBS BSS 143 chronology line around 2334 for time of collapse."
        ]
      }
    ],
