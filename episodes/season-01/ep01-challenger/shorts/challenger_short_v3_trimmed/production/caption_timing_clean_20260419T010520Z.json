  "segments": [
    {
      "segment_id": "caption_clean_001",
      "start_seconds": 0.031,
      "end_seconds": 4.336,
      "text": "The night before Challenger launched, Roger Boisjoly told NASA not to fly."
    },
    {
      "segment_id": "caption_clean_002",
      "start_seconds": 5.258,
      "end_seconds": 5.958,
      "text": "He had the data."
    },
    {
      "segment_id": "caption_clean_003",
      "start_seconds": 6.719,
      "end_seconds": 11.185,
      "text": "They launched anyway, and the reason is more disturbing than the explosion itself."
    },
    {
      "segment_id": "caption_clean_004",
      "start_seconds": 12.188,
      "end_seconds": 16.053,
      "text": "The booster O-rings had shown erosion and blow-by before."
    },
    {
      "segment_id": "caption_clean_005",
      "start_seconds": 17.074,
      "end_seconds": 20.158,
      "text": "Each flight that survived made the warning look more normal."
    },
    {
      "segment_id": "caption_clean_006",
      "start_seconds": 21.140,
      "end_seconds": 24.925,
      "text": "Management had started treating the damage as acceptable."
    },
    {
      "segment_id": "caption_clean_007",
      "start_seconds": 25.359,
      "end_seconds": 30.025,
      "text": "On January 27th, NASA did not ask Thiokol to prove launch was safe."
    },
    {
      "segment_id": "caption_clean_008",
      "start_seconds": 30.847,
      "end_seconds": 32.569,
      "text": "It asked them to prove it was unsafe."
    },
    {
      "segment_id": "caption_clean_009",
      "start_seconds": 33.631,
      "end_seconds": 36.975,
      "text": "At ignition, smoke appeared from the right booster joint."
    },
    {
      "segment_id": "caption_clean_010",
      "start_seconds": 37.936,
      "end_seconds": 41.942,
      "text": "Around 58 to 59 seconds, flame became visible again."
    },
    {
      "segment_id": "caption_clean_011",
      "start_seconds": 42.802,
      "end_seconds": 45.786,
      "text": "At 73 seconds, Challenger broke apart."
    },
    {
      "segment_id": "caption_clean_012",
      "start_seconds": 46.588,
      "end_seconds": 47.548,
      "text": "Seven people died."
    },
    {
      "segment_id": "caption_clean_013",
      "start_seconds": 48.409,
      "end_seconds": 50.472,
      "text": "This was not one bad call."
    },
    {
      "segment_id": "caption_clean_014",
      "start_seconds": 50.472,
      "end_seconds": 53.414,
      "text": "It was a system that learned to look at damage and call it normal."
    },
    {
      "segment_id": "caption_clean_015",
      "start_seconds": 54.240,
      "end_seconds": 57.307,
      "text": "Small causes, massive consequences."
    }
  ]
}
