      "text": "looked like a shortcut.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_003",
      "start_seconds": 7.599,
      "end_seconds": 9.282,
      "text": "The walkway design used one continuous",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_004",
      "start_seconds": 9.282,
      "end_seconds": 10.964,
      "text": "hangar rod from roof to fourth floor",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_005",
      "start_seconds": 10.964,
      "end_seconds": 12.647,
      "text": "to second floor.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_006",
      "start_seconds": 13.609,
      "end_seconds": 15.923,
      "text": "In shop drawings, it became two shorter",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_007",
      "start_seconds": 15.923,
      "end_seconds": 18.237,
      "text": "rods, easier to build.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_008",
      "start_seconds": 19.198,
      "end_seconds": 20.561,
      "text": "But the load path changed.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_009",
      "start_seconds": 21.222,
      "end_seconds": 23.155,
      "text": "The fourth floor connection now carried both",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_010",
      "start_seconds": 23.155,
      "end_seconds": 25.088,
      "text": "walkways, not one.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_011",
      "start_seconds": 25.85,
      "end_seconds": 27.772,
      "text": "The load essentially doubled.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_012",
      "start_seconds": 27.888,
      "end_seconds": 29.742,
      "text": "NBS later found the original design was",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_013",
      "start_seconds": 29.742,
      "end_seconds": 31.596,
      "text": "already weak.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_014",
      "start_seconds": 31.615,
      "end_seconds": 33.269,
      "text": "The revision left roughly one-third of",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_015",
      "start_seconds": 33.269,
      "end_seconds": 34.923,
      "text": "code-expected capacity.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_016",
      "start_seconds": 35.845,
      "end_seconds": 38.561,
      "text": "On July 17, 1981, two walkways collapsed",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_017",
      "start_seconds": 38.561,
      "end_seconds": 41.277,
      "text": "during a crowded dance.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_018",
      "start_seconds": 42.079,
      "end_seconds": 44.755,
      "text": "Official records count 113 dead and 186",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_019",
      "start_seconds": 44.755,
      "end_seconds": 47.432,
      "text": "injured.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_020",
      "start_seconds": 47.868,
      "end_seconds": 49.354,
      "text": "This was not a shop detail.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_021",
      "start_seconds": 49.395,
      "end_seconds": 52.207,
      "text": "It was a structural redesign.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_022",
      "start_seconds": 53.192,
      "end_seconds": 55.261,
      "text": "Every handoff treated it like paperwork.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_023",
      "start_seconds": 55.863,
