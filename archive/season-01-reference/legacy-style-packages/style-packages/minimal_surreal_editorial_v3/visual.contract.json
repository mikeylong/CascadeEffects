{
  "$schema": "https://surfaces.systems/schemas/visual-contract-v1.json",
  "contract_version": "3.0.0-draft",
  "id": "minimal-surreal-editorial-v3",
  "name": "Minimal Surreal Editorial Composition v3",
  "intent": "Generate restrained documentary-surreal images with a clear renderable subject, one dominant anomaly, controlled palette, and strong thumbnail clarity.",
  "render_targets": {
    "aspect_ratios": [
      "1:1",
      "4:5",
      "3:4",
      "9:16",
      "16:9"
    ],
    "min_resolution": {
      "width": 1024,
      "height": 1024
    }
  },
  "global_rules": {
    "max_subject_clusters": 4,
    "primary_focal_points": 1,
    "negative_space_ratio": {
      "min": 0.2,
      "preferred": 0.4
    },
    "max_palette_count": 5,
    "max_accent_colors": 1,
    "surreal_breach_count": 1,
    "allow_text": false,
    "allow_logo": false,
    "allow_ui_artifacts": false,
    "allow_motion_blur": false,
    "allow_photoreal_clutter": false
  },
  "composition": {
    "symmetry": {
      "allowed": true,
      "preferred": "clarity_first",
      "max_center_balance_score": 0.8
    },
    "weight_distribution": {
      "required": "readable",
      "dominant_side_required": false
    },
    "horizon_or_division_line": {
      "preferred": false,
      "required_in_patterns": []
    },
    "subject_placement": {
      "allowed_zones": [
        "far_left",
        "left_third",
        "center_third",
        "right_third",
        "far_right",
        "boundary_edge"
      ]
    },
    "depth": {
      "preferred": "moderate",
      "max_layers": 6
    }
  },
  "form_language": {
    "geometry_bias": "medium",
    "detail_level": "restrained",
    "edge_quality": "clear",
    "texture_level": "restrained",
    "micro_detail": {
      "allowed": true,
      "level": "limited"
    },
    "human_figure_rules": {
      "allowed": true,
      "max_count": 4,
      "facial_detail": "none_or_negligible",
      "pose": "still_or_incidental"
    }
  },
  "color": {
    "dominant_field": {
      "required": false,
      "preferred": true,
      "saturation": "low_to_medium"
    },
    "accent": {
      "required": false,
      "count": 1,
      "saturation": "muted_to_high",
      "role": "semantic_or_state_signal"
    },
    "allowed_neutrals": [
      "off_white",
      "beige",
      "gray",
      "charcoal",
      "muted_blue",
      "desaturated_green",
      "pale_cyan",
      "desaturated_steel",
      "weathered_brown"
    ],
    "avoid": [
      "rainbow_palettes",
      "multiple_competing_accents",
      "high_frequency_color_noise"
    ]
  },
  "lighting": {
    "style": "controlled_flat_soft_or_gently_directional",
    "dramatic_shadows": false,
    "hard_rim_light": false,
    "specular_intensity": "low_to_moderate",
    "mood": "restrained_tense_or_quiet"
  },
  "surrealism": {
    "mode": "single_dominant_anomaly",
    "examples": [
      "duplicated state cue",
      "wrong seam or internal glow",
      "missing or extra component",
      "impossible reflection or boundary",
      "one contradictory physical condition"
    ],
    "forbidden": [
      "stacked dream logic",
      "melting objects",
      "floating eyes",
      "crowded symbolic collage",
      "multiple unrelated impossible events",
      "glitch spectacle"
    ]
  },
  "patterns": [
    {
      "id": "subject_first_reduction",
      "rules": {
        "identity_before_style": true,
        "single_subject_preferred": true,
        "supporting_objects_limited": true
      }
    },
    {
      "id": "readable_scene_state",
      "rules": {
        "main_state_clear": true,
        "explanation_elements_limited": true,
        "supporting_context_subordinate": true
      }
    },
    {
      "id": "quiet_integrated_anomaly",
      "rules": {
        "anomaly_integrated_into_subject_or_scene": true,
        "anomaly_count": 1,
        "spectacle_forbidden": true
      }
    }
  ],
  "output_quality": {
    "thumbnail_readability": {
      "required": true,
      "min_score": 0.8
    },
    "focal_clarity": {
      "required": true,
      "min_score": 0.78
    },
    "visual_noise": {
      "max_score": 0.35
    }
  },
  "negative_prompt_defaults": [
    "text",
    "watermark",
    "logo",
    "ui overlay",
    "crowded scene",
    "many small objects",
    "unreadable background detail",
    "motion blur",
    "action pose",
    "blockbuster cinematic lighting",
    "poster design",
    "collage fragments",
    "multiple surreal events",
    "competing bright accents"
  ]
}
