    },
    {
      "segment_id": "caption_002",
      "start_seconds": 5.281,
      "end_seconds": 6.617,
      "text": "looked like a shortcut.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_003",
      "start_seconds": 7.599,
      "end_seconds": 9.714,
      "text": "The walkway design used one continuous",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_004",
      "start_seconds": 9.714,
      "end_seconds": 11.76,
      "text": "hanger rod from roof to fourth floor",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_005",
      "start_seconds": 11.76,
      "end_seconds": 13.345,
      "text": "to second floor.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_006",
      "start_seconds": 13.345,
      "end_seconds": 14.931,
      "text": "In shop drawings,",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_007",
      "start_seconds": 14.931,
      "end_seconds": 17.009,
      "text": "it became two shorter rods.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_008",
      "start_seconds": 17.009,
      "end_seconds": 18.558,
      "text": "Easier to build.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_009",
      "start_seconds": 18.558,
      "end_seconds": 20.107,
      "text": "But the load path",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_010",
      "start_seconds": 20.107,
      "end_seconds": 21.709,
      "text": "changed.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_011",
      "start_seconds": 21.709,
      "end_seconds": 23.31,
      "text": "The fourth-floor connection now",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_012",
      "start_seconds": 23.31,
      "end_seconds": 25.088,
      "text": "carried both walkways, not one.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_013",
      "start_seconds": 25.85,
      "end_seconds": 27.772,
      "text": "The load essentially doubled.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_014",
      "start_seconds": 27.888,
      "end_seconds": 31.337,
      "text": "NBS later found the original design was",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_015",
      "start_seconds": 31.337,
      "end_seconds": 34.786,
      "text": "already weak; the revision left roughly",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_016",
      "start_seconds": 34.786,
      "end_seconds": 37.921,
      "text": "one-third of code-expected capacity.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_017",
      "start_seconds": 37.921,
      "end_seconds": 41.266,
      "text": "On July 17, 1981, two walkways collapsed",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_018",
      "start_seconds": 41.266,
      "end_seconds": 43.251,
      "text": "during a crowded dance.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_019",
      "start_seconds": 43.251,
      "end_seconds": 46.7,
      "text": "Official records count 113 dead and 186",
