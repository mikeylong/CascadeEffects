      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_019",
      "start_seconds": 44.411,
      "end_seconds": 46.774,
      "text": "That was the problem.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_020",
      "start_seconds": 46.753,
      "end_seconds": 48.367,
      "text": "Believing the data meant believing doctors had",
