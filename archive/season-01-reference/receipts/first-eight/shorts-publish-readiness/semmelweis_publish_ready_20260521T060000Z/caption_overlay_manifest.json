      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_003",
      "start_seconds": 7.397,
      "end_seconds": 8.549,
      "text": "The First Clinic was run by doctors",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_004",
