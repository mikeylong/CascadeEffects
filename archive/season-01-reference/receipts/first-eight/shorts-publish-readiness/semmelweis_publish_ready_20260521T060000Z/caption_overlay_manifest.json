    },
    {
      "segment_id": "caption_005",
      "start_seconds": 10.602,
      "end_seconds": 12.144,
      "text": "The Second was run by midwives.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_006",
      "start_seconds": 12.926,
      "end_seconds": 14.087,
      "text": "The patients were similar.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_007",
      "start_seconds": 14.868,
      "end_seconds": 16.111,
      "text": "The death rates were not.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_008",
      "start_seconds": 17.071,
      "end_seconds": 19.756,
      "text": "By 1846, the First Clinic was losing",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_009",
      "start_seconds": 19.756,
      "end_seconds": 22.44,
      "text": "more than one in ten mothers.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_010",
      "start_seconds": 22.42,
      "end_seconds": 24.202,
      "text": "Across the same years, the Second stayed",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_011",
      "start_seconds": 24.202,
      "end_seconds": 25.984,
      "text": "under four percent.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_012",
      "start_seconds": 26.846,
      "end_seconds": 28.989,
      "text": "Semmelweis found the difference in the routine.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_013",
      "start_seconds": 29.048,
      "end_seconds": 32.023,
      "text": "Doctors moved from autopsies to childbirth without",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_014",
      "start_seconds": 32.023,
      "end_seconds": 34.998,
      "text": "effective disinfection.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_015",
      "start_seconds": 35.819,
      "end_seconds": 38.442,
      "text": "He required chloride-of-lime hand disinfection.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_016",
      "start_seconds": 39.463,
      "end_seconds": 40.384,
      "text": "Mortality fell.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_017",
      "start_seconds": 41.447,
