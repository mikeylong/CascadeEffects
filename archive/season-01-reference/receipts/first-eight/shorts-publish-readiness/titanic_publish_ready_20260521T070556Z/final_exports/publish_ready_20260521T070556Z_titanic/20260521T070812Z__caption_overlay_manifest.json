      "text": "law.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_003",
      "start_seconds": 6.434,
      "end_seconds": 7.714,
      "text": "That sentence sounds safe.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_004",
      "start_seconds": 8.575,
      "end_seconds": 11.337,
      "text": "In 1912, it was the problem.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_005",
      "start_seconds": 12.619,
      "end_seconds": 15.002,
      "text": "British rules measured lifeboats by tonnage.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_006",
      "start_seconds": 15.882,
      "end_seconds": 18.934,
      "text": "Above 10,000 tons, the top bracket required",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_007",
      "start_seconds": 18.934,
      "end_seconds": 21.987,
      "text": "16 lifeboats for 990 people.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_008",
      "start_seconds": 22.888,
      "end_seconds": 26.192,
      "text": "Titanic carried 16 lifeboats and four collapsibles,",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_009",
      "start_seconds": 26.192,
      "end_seconds": 29.495,
      "text": "enough for about 1,176 people.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_010",
      "start_seconds": 30.396,
      "end_seconds": 33.038,
      "text": "More than 2,200 were aboard.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_011",
      "start_seconds": 33.018,
      "end_seconds": 34.58,
      "text": "The paperwork said compliant.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_012",
      "start_seconds": 35.262,
      "end_seconds": 36.363,
      "text": "The ship said otherwise.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_013",
      "start_seconds": 37.164,
      "end_seconds": 38.527,
      "text": "Some boats left underfilled.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_014",
      "start_seconds": 39.189,
      "end_seconds": 40.231,
      "text": "The law failed one way.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_015",
      "start_seconds": 40.832,
      "end_seconds": 42.234,
      "text": "Evacuation failed another.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_016",
      "start_seconds": 43.316,
      "end_seconds": 45.5,
      "text": "Afterward, investigators pushed the correction.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_017",
      "start_seconds": 46.161,
      "end_seconds": 48.304,
      "text": "Count people carried, not tonnage.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
    },
    {
      "segment_id": "caption_018",
      "start_seconds": 49.347,
      "end_seconds": 51.431,
      "text": "Two years later, SOLAS turned that lesson",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_019",
      "start_seconds": 51.431,
      "end_seconds": 53.514,
      "text": "into international rulemaking.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_020",
      "start_seconds": 54.375,
      "end_seconds": 56.279,
      "text": "The old category kept measuring yesterday's ship",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_021",
      "start_seconds": 56.279,
      "end_seconds": 58.182,
      "text": "while approving tomorrow's risk.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": "split from longer timed caption for phrase-level Shorts overlay"
    },
    {
      "segment_id": "caption_022",
      "start_seconds": 58.984,
      "end_seconds": 62.35,
      "text": "Small causes, massive consequences.",
      "emphasis_words": [],
      "placement_override": "",
      "timing_adjustment_note": ""
