.DS_Store

# Local secrets and machine state.
.env
.env.*
**/.env
**/.env.*
*.pid
*.log
*.tmp
*.swp
*.pyc
__pycache__/
.pytest_cache/
.playwright-cli/
test-results/

# Dependency/build outputs.
node_modules/
**/node_modules/
.next/
**/.next/
out/
dist/
build/
coverage/
.cache/
tmp/
**/tmp/
output/
**/output/
work/
**/work/
workflows/generated/

# Local artifact store. Git tracks manifests and checksums, not heavy renders.
.artifacts/

# Generated or binary media stays outside Git except deployed web public assets.
*.aiff
*.AIFF
*.ckpt
*.CKPT
*.flac
*.FLAC
*.gif
*.GIF
*.jpeg
*.JPEG
*.jpg
*.JPG
*.m4a
*.M4A
*.mkv
*.MKV
*.mov
*.MOV
*.mp3
*.MP3
*.mp4
*.MP4
*.onnx
*.ONNX
*.pdf
*.PDF
*.png
*.PNG
*.pt
*.PT
*.pth
*.PTH
*.raw
*.safetensor
*.SAFETENSOR
*.safetensors
*.SAFETENSORS
*.wav
*.WAV
*.webp
*.WEBP

# Web public assets are deploy inputs for Vercel.
!apps/web/app/icon.png
!apps/web/public/**
!apps/web/brand/assets/**
