#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
. "${SCRIPT_DIR}/../scripts/lib.sh"

sl_load_config
sl_create_runtime_dirs
sl_require_file "${CE_STYLELAB_PYTHON}"

exec "${CE_STYLELAB_PYTHON}" "${SL_ROOT}/scripts/cestyle_tool.py" \
  --repo-root "${SL_ROOT}" \
  "$@"
