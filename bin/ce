from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from dataclasses import dataclass
from datetime import datetime, timedelta, timezone
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
ARTIFACT_ROOT = ROOT / ".artifacts"
DEFAULT_SEASON = "season-02"
AUDIO_PIPELINE_SCRIPT = ROOT / "packages" / "media-pipeline" / "audio" / "scripts" / "cascade_tts_pipeline.sh"
AUDIO_CHUNK_MAX_CHARS = 2600
MEDIA_EXTENSIONS = {
    ".aiff", ".flac", ".gif", ".jpeg", ".jpg", ".m4a", ".mkv", ".mov", ".mp3", ".mp4",
    ".pdf", ".png", ".raw", ".wav", ".webp",
}
APPROVED_MEDIA_PREFIXES = [
    ROOT / "apps" / "web" / "public",
    ROOT / "apps" / "web" / "brand" / "assets",
]
APPROVED_MEDIA_FILES = {
    ROOT / "apps" / "web" / "app" / "icon.png",
}
LEGACY_REFERENCE_EXCLUDES = [
    ROOT / "archive",
    ROOT / "ops" / "migration",
]
LEGACY_TOP_LEVEL_DIRS = {"agents", "audio", "viz", "inbox", "labs", "channel"}
LEGACY_EPISODE_DIR = ROOT / "episodes" / "season-01"
OLD_ROOT_STEMS = [
    "Agents",
    "Audio",
    "Episodes",
    "Inbox",
    "StyleLab",
    "Viz",
    "Web",
    "FluxLab",
]


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def run(cmd: list[str], cwd: Path = ROOT, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, check=check, text=True, capture_output=True)


def rel(path: Path) -> str:
    return str(path.relative_to(ROOT))


def load_json(path: Path, default):
    if not path.exists():
        return default
    return json.loads(path.read_text())


def write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2) + "\n")


def sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def is_under(path: Path, parent: Path) -> bool:
    try:
        path.relative_to(parent)
        return True
    except ValueError:
        return False


@dataclass(frozen=True)
class EpisodeContext:
    season: str
    episode_id: str
    episode_dir: Path
    title: str
    script_path: Path
    preflight_path: Path
    approval_receipt_path: Path
    episode_toml_path: Path
    state_path: Path
    tasks_path: Path
    artifact_lock_path: Path


def safe_rel(path: Path) -> str:
    try:
        return rel(path)
    except ValueError:
        return str(path)


def resolve_path_token(value: Any) -> Path:
    path = Path(str(value)).expanduser()
    if path.is_absolute():
        return path
    return ROOT / path


def read_toml_string_value(path: Path, key: str, default: str = "") -> str:
    if not path.exists():
        return default
    pattern = re.compile(rf"^\s*{re.escape(key)}\s*=\s*\"([^\"]*)\"")
    for line in path.read_text(encoding="utf-8").splitlines():
        match = pattern.match(line)
        if match:
            return match.group(1)
    return default


def read_gate_status(episode_toml: Path, gate: str, default: str = "") -> str:
    if not episode_toml.exists():
        return default
    in_gates = False
    pattern = re.compile(rf"^\s*{re.escape(gate)}\s*=\s*\"([^\"]*)\"")
    for line in episode_toml.read_text(encoding="utf-8").splitlines():
        stripped = line.strip()
        if stripped.startswith("[") and stripped.endswith("]"):
            in_gates = stripped == "[gates]"
            continue
        if not in_gates:
            continue
        match = pattern.match(line)
        if match:
            return match.group(1)
    return default


def write_gate_status(episode_toml: Path, gate: str, status_value: str) -> None:
    lines = episode_toml.read_text(encoding="utf-8").splitlines()
    output: list[str] = []
    in_gates = False
    wrote = False
    gate_line = f'{gate} = "{status_value}"'
    pattern = re.compile(rf"^\s*{re.escape(gate)}\s*=")

    for line in lines:
        stripped = line.strip()
        if stripped.startswith("[") and stripped.endswith("]"):
            if in_gates and not wrote:
                output.append(gate_line)
                wrote = True
            in_gates = stripped == "[gates]"
            output.append(line)
            continue
        if in_gates and pattern.match(line):
            output.append(gate_line)
            wrote = True
            continue
        output.append(line)

    if in_gates and not wrote:
        output.append(gate_line)
    episode_toml.write_text("\n".join(output) + "\n", encoding="utf-8")


def resolve_episode_dir(
    episode_id: str | None = None,
    *,
    season: str = DEFAULT_SEASON,
    cwd: Path | None = None,
) -> Path:
    season_root = ROOT / "episodes" / season
    if episode_id:
        episode_dir = season_root / episode_id
        if not episode_dir.exists():
            raise SystemExit(f"episode not found: {safe_rel(episode_dir)}")
        return episode_dir

    current = (cwd or Path.cwd()).resolve()
    try:
        relative = current.relative_to(season_root.resolve())
    except ValueError:
        raise SystemExit("episode_id is required when not running from a Season 2 episode folder")
    if not relative.parts:
        raise SystemExit("episode_id is required from the season root")
    inferred = season_root / relative.parts[0]
    if not (inferred / "episode.toml").exists():
        raise SystemExit(f"could not infer episode from cwd: {current}")
    return inferred


def resolve_episode_context(
    episode_id: str | None = None,
    *,
    season: str = DEFAULT_SEASON,
    cwd: Path | None = None,
) -> EpisodeContext:
    episode_dir = resolve_episode_dir(episode_id, season=season, cwd=cwd)
    episode_toml = episode_dir / "episode.toml"
    parsed_episode_id = read_toml_string_value(episode_toml, "episode_id", episode_dir.name)
    title = read_toml_string_value(episode_toml, "title", parsed_episode_id.replace("-", " ").title())
    return EpisodeContext(
        season=season,
        episode_id=parsed_episode_id,
        episode_dir=episode_dir,
        title=title,
        script_path=episode_dir / "source" / "longform-script.md",
        preflight_path=episode_dir / "source" / "elevenlabs-preflight.md",
        approval_receipt_path=episode_dir / "receipts" / "human-script-approval-for-audio.json",
        episode_toml_path=episode_toml,
        state_path=episode_dir / "state.json",
        tasks_path=episode_dir / "tasks.jsonl",
        artifact_lock_path=episode_dir / "artifacts.lock.json",
    )


def load_required_json(path: Path) -> dict[str, Any]:
    if not path.exists():
        raise SystemExit(f"missing required file: {safe_rel(path)}")
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"invalid JSON: {safe_rel(path)}: {exc}") from exc
    if not isinstance(data, dict):
        raise SystemExit(f"expected JSON object: {safe_rel(path)}")
    return data


def validate_audio_render_authorization(ctx: EpisodeContext, script_sha: str) -> dict[str, dict[str, Any]]:
    if not ctx.script_path.exists():
        raise SystemExit(f"missing script: {safe_rel(ctx.script_path)}")
    if not ctx.preflight_path.exists():
        raise SystemExit(f"missing preflight note: {safe_rel(ctx.preflight_path)}")

    preflight_receipt = load_required_json(ctx.episode_dir / "receipts" / "elevenlabs-preflight.json")
    approval_receipt = load_required_json(ctx.approval_receipt_path)
    preflight_sha = str(
        preflight_receipt.get("script_sha256_current")
        or preflight_receipt.get("script_sha256_reviewed")
        or ""
    ).strip()
    approval_sha = str(approval_receipt.get("script_sha256_reviewed", "")).strip()
    if preflight_sha != script_sha:
        raise SystemExit("elevenlabs preflight receipt does not match the current script hash")
    if approval_sha != script_sha:
        raise SystemExit("human script approval receipt does not match the current script hash")
    reads = approval_receipt.get("reads", {})
    authorized = bool(approval_receipt.get("audio_render_authorized")) or bool(
        reads.get("audio_render_authorized") if isinstance(reads, dict) else False
    )
    if not authorized:
        raise SystemExit("human script approval receipt does not authorize audio render")
    return {"preflight": preflight_receipt, "approval": approval_receipt}


def flush_paragraph(paragraphs: list[str], pending: list[str]) -> None:
    text = " ".join(part.strip() for part in pending if part.strip()).strip()
    pending.clear()
    if text:
        paragraphs.append(text)


def audio_script_paragraphs(ctx: EpisodeContext) -> list[str]:
    title = ctx.title.strip() or ctx.episode_id.replace("-", " ").title()
    paragraphs: list[str] = [title]
    pending: list[str] = []
    skipping_title_section = False
    seen_body = False

    for raw in ctx.script_path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line:
            flush_paragraph(paragraphs, pending)
            continue
        if line.startswith("#"):
            flush_paragraph(paragraphs, pending)
            heading = line.lstrip("#").strip()
            lowered = heading.lower()
            if "review notes" in lowered:
                break
            skipping_title_section = lowered == "title"
            continue
        if skipping_title_section:
            continue
        if not seen_body and re.match(r"^[A-Za-z_][A-Za-z0-9_ -]*:\s*", line):
            continue
        seen_body = True
        pending.append(line)

    flush_paragraph(paragraphs, pending)
    deduped: list[str] = []
    for paragraph in paragraphs:
        if not deduped or paragraph != deduped[-1]:
            deduped.append(paragraph)
    return deduped


def split_long_paragraph(paragraph: str, max_chars: int) -> list[str]:
    if len(paragraph) <= max_chars:
        return [paragraph]
    sentences = re.findall(r".+?(?:[.!?]+(?:[\"')\]]*)|$)", paragraph)
    chunks: list[str] = []
    current: list[str] = []
    for sentence in [item.strip() for item in sentences if item.strip()]:
        candidate = " ".join([*current, sentence]).strip()
        if current and len(candidate) > max_chars:
            chunks.append(" ".join(current).strip())
            current = [sentence]
        else:
            current.append(sentence)
    if current:
        chunks.append(" ".join(current).strip())
    return chunks or [paragraph]


def chunk_audio_paragraphs(paragraphs: list[str], max_chars: int = AUDIO_CHUNK_MAX_CHARS) -> list[str]:
    chunks: list[str] = []
    current: list[str] = []
    for paragraph in paragraphs:
        pieces = split_long_paragraph(paragraph, max_chars)
        for piece in pieces:
            candidate = "\n\n".join([*current, piece]).strip()
            if current and len(candidate) > max_chars:
                chunks.append("\n\n".join(current).strip())
                current = [piece]
            else:
                current.append(piece)
    if current:
        chunks.append("\n\n".join(current).strip())
    return chunks


def write_audio_render_manifest(ctx: EpisodeContext, artifact_dir: Path, script_sha: str) -> Path:
    authorizations = validate_audio_render_authorization(ctx, script_sha)
    preflight_receipt = authorizations["preflight"]
    approval_receipt = authorizations["approval"]
    manifest_dir = artifact_dir / "manifests"
    manifest_dir.mkdir(parents=True, exist_ok=True)
    render_jobs_path = manifest_dir / "render-jobs.jsonl"
    narration_path = manifest_dir / "narration.txt"

    chunks = chunk_audio_paragraphs(audio_script_paragraphs(ctx))
    narration_path.write_text("\n\n".join(chunks) + "\n", encoding="utf-8")

    preflight_sha = sha256(ctx.preflight_path)
    approval_sha = sha256(ctx.approval_receipt_path)
    rows = []
    for index, chunk in enumerate(chunks, start=1):
        rows.append(
            {
                "out": f"chunks/{ctx.episode_id}_chunk_{index:03d}.wav",
                "input": chunk,
                "speed": 0.95,
                "episode_id": ctx.episode_id,
                "chunk_index": index,
                "chunk_count": len(chunks),
                "source_script_path": safe_rel(ctx.script_path),
                "source_script_sha256": script_sha,
                "preflight_path": safe_rel(ctx.preflight_path),
                "preflight_sha256": preflight_sha,
                "preflight_receipt_path": safe_rel(ctx.episode_dir / "receipts" / "elevenlabs-preflight.json"),
                "preflight_receipt_sha256": sha256(ctx.episode_dir / "receipts" / "elevenlabs-preflight.json"),
                "approval_receipt_path": safe_rel(ctx.approval_receipt_path),
                "approval_receipt_sha256": approval_sha,
                "approval_script_sha256_reviewed": approval_receipt.get("script_sha256_reviewed", ""),
                "preflight_script_sha256_reviewed": preflight_receipt.get("script_sha256_reviewed", ""),
            }
        )
    render_jobs_path.write_text(
        "\n".join(json.dumps(row, ensure_ascii=False) for row in rows) + "\n",
        encoding="utf-8",
    )
    return render_jobs_path


def build_season2_audio_env(ctx: EpisodeContext) -> tuple[dict[str, str], Path]:
    script_sha = sha256(ctx.script_path)
    artifact_dir = ARTIFACT_ROOT / ctx.season / ctx.episode_id / "audio" / script_sha[:12]
    render_jobs = write_audio_render_manifest(ctx, artifact_dir, script_sha)
    package_out = artifact_dir / "longform-narration.wav"
    env = {
        "EPISODE_DIR": str(ctx.episode_dir),
        "EPISODE_SCRIPT": str(ctx.script_path),
        "EPISODE_FINAL_OUT": str(package_out),
        "AUDIO_PACKAGE_PATH": str(artifact_dir / "audio-package.json"),
        "PIPELINE_DIR": str(artifact_dir),
        "FINAL_JOBS": str(render_jobs),
        "RENDER_OUT_DIR": str(artifact_dir),
        "MASTER_OUT": str(artifact_dir / "mastering" / "longform-narration.master.wav"),
        "PREMASTER_OUT": str(artifact_dir / "mastering" / "premaster.wav"),
        "MASTERING_DIR": str(artifact_dir / "mastering"),
        "TRANSCRIPT_OUT_DIR": str(artifact_dir / "transcript-qa"),
        "PROSODY_GUARD_DIR": str(artifact_dir / "prosody-guard"),
        "WARMUP_TRIM_DIR": str(artifact_dir / "warmup-trim"),
        "REQUIRE_CANONICAL_CUE_TAGS": "0",
        "ELEVENLABS_STRICT_SOURCE_ALIGNMENT": "0",
    }
    return env, artifact_dir


def audio_keep(args: argparse.Namespace) -> int:
    ctx = resolve_episode_context(args.episode_id)
    env = os.environ.copy()
    season_env, artifact_dir = build_season2_audio_env(ctx)
    env.update(season_env)
    print(f"episode: {ctx.episode_id}")
    print(f"artifact_root: {safe_rel(artifact_dir)}")
    completed = subprocess.run(
        [str(AUDIO_PIPELINE_SCRIPT), args.audio_command],
        cwd=AUDIO_PIPELINE_SCRIPT.parent,
        env=env,
    )
    return completed.returncode


def first_jsonl_object(path: Path) -> dict[str, Any]:
    if not path.exists():
        return {}
    for raw in path.read_text(encoding="utf-8").splitlines():
        line = raw.strip()
        if not line:
            continue
        try:
            loaded = json.loads(line)
        except json.JSONDecodeError:
            return {}
        return loaded if isinstance(loaded, dict) else {}
    return {}


def assert_under_artifacts(path: Path, label: str) -> None:
    resolved = path.resolve(strict=False)
    artifact_root = ARTIFACT_ROOT.resolve(strict=False)
    try:
        resolved.relative_to(artifact_root)
    except ValueError as exc:
        raise SystemExit(f"{label} must be under .artifacts: {path}") from exc


def package_field_path(package: dict[str, Any], *fields: str) -> Path | None:
    for field in fields:
        value = str(package.get(field, "")).strip()
        if value:
            return resolve_path_token(value)
    return None


def package_field_sha(package: dict[str, Any], *fields: str) -> str:
    for field in fields:
        value = str(package.get(field, "")).strip()
        if value:
            return value
    return ""


def default_audio_package_path(ctx: EpisodeContext) -> Path:
    script_sha = sha256(ctx.script_path)
    artifact_dir = ARTIFACT_ROOT / ctx.season / ctx.episode_id / "audio" / script_sha[:12]
    for name in ("audio-package.json", "audio_package.json"):
        candidate = artifact_dir / name
        if candidate.exists():
            return candidate
    return artifact_dir / "audio-package.json"


def validate_promotable_audio_package(ctx: EpisodeContext, package_path: Path) -> dict[str, Any]:
    package_path = resolve_path_token(package_path)
    if not package_path.exists():
        raise SystemExit(f"audio package is missing: {safe_rel(package_path)}")
    assert_under_artifacts(package_path, "audio package")
    package = load_required_json(package_path)
    current_script_sha = sha256(ctx.script_path)
    authorizations = validate_audio_render_authorization(ctx, current_script_sha)

    audio_path = package_field_path(package, "packaged_path", "master_audio_path")
    if audio_path is None or not audio_path.exists():
        raise SystemExit("audio package is missing packaged_path/master_audio_path or the audio file does not exist")
    assert_under_artifacts(audio_path, "packaged audio")

    transcript_path = package_field_path(
        package,
        "transcript_path",
        "transcript_txt_path",
        "transcript_srt_path",
        "transcript_vtt_path",
    )
    if transcript_path is None or not transcript_path.exists():
        raise SystemExit("audio package is missing a QA transcript path or the transcript file does not exist")
    assert_under_artifacts(transcript_path, "QA transcript")

    effective_manifest_path = package_field_path(package, "effective_manifest_path")
    first_job = first_jsonl_object(effective_manifest_path) if effective_manifest_path else {}
    if effective_manifest_path and effective_manifest_path.exists():
        assert_under_artifacts(effective_manifest_path, "effective manifest")
    source_script_sha = str(package.get("source_script_sha256") or first_job.get("source_script_sha256") or "").strip()
    if source_script_sha != current_script_sha:
        raise SystemExit("audio package source_script_sha256 does not match the current script hash")

    expected_audio_sha = package_field_sha(package, "packaged_sha256", "master_audio_sha256")
    if expected_audio_sha and sha256(audio_path) != expected_audio_sha:
        raise SystemExit("packaged audio checksum does not match audio package metadata")
    expected_transcript_sha = package_field_sha(package, "transcript_sha256", "transcript_txt_sha256", "transcript_srt_sha256")
    if expected_transcript_sha and sha256(transcript_path) != expected_transcript_sha:
        raise SystemExit("QA transcript checksum does not match audio package metadata")

    preflight_receipt = authorizations["preflight"]
    approval_receipt = authorizations["approval"]
    return {
        "package": package,
        "package_path": package_path,
        "package_sha256": sha256(package_path),
        "audio_path": audio_path,
        "audio_sha256": sha256(audio_path),
        "transcript_path": transcript_path,
        "transcript_sha256": sha256(transcript_path),
        "effective_manifest_path": effective_manifest_path if effective_manifest_path and effective_manifest_path.exists() else None,
        "effective_manifest_sha256": sha256(effective_manifest_path) if effective_manifest_path and effective_manifest_path.exists() else "",
        "source_script_sha256": current_script_sha,
        "preflight_receipt": preflight_receipt,
        "approval_receipt": approval_receipt,
        "chunk_count": int(package.get("chunk_count") or first_job.get("chunk_count") or 0),
    }


def artifact_item(ctx: EpisodeContext, artifact_id: str, kind: str, status_value: str, path: Path, source_manifest: Path | None = None) -> dict[str, Any]:
    return {
        "id": artifact_id,
        "kind": kind,
        "status": status_value,
        "repo_path": None,
        "artifact_path": safe_rel(path),
        "original_path": str(path),
        "sha256": sha256(path),
        "bytes": path.stat().st_size,
        "created_at": utc_now(),
        "source_stage": "audio_keep",
        "episode": ctx.episode_id,
        "source_manifest": safe_rel(source_manifest) if source_manifest else "",
    }


def update_audio_artifact_lock(ctx: EpisodeContext, validation: dict[str, Any], *, kept: bool) -> Path:
    lock = load_json(
        ctx.artifact_lock_path,
        {"schema_version": 1, "episode": ctx.episode_id, "generated_at": utc_now(), "artifacts": []},
    )
    artifacts = lock.setdefault("artifacts", [])
    by_id = {str(item.get("id", "")): item for item in artifacts if isinstance(item, dict)}
    source_manifest = validation.get("effective_manifest_path")
    audio_status = "keep_artifact" if kept else "review_ready_artifact"
    items = [
        artifact_item(
            ctx,
            f"{ctx.episode_id}:audio_keep:longform-narration.wav",
            "longform_narration_wav",
            audio_status,
            validation["audio_path"],
            source_manifest,
        ),
        artifact_item(
            ctx,
            f"{ctx.episode_id}:audio_keep:audio-package.json",
            "audio_package_manifest",
            "production_receipt",
            validation["package_path"],
            source_manifest,
        ),
    ]
    if source_manifest:
        items.append(
            artifact_item(
                ctx,
                f"{ctx.episode_id}:audio_keep:{source_manifest.name}",
                "audio_effective_manifest",
                "production_receipt",
                source_manifest,
                source_manifest,
            )
        )
    transcript_path = validation["transcript_path"]
    transcript_kind = {
        ".srt": "audio_qa_transcript_srt",
        ".vtt": "audio_qa_transcript_vtt",
        ".json": "audio_qa_transcript_json",
    }.get(transcript_path.suffix.lower(), "audio_qa_transcript_txt")
    items.append(
        artifact_item(
            ctx,
            f"{ctx.episode_id}:audio_keep:{transcript_path.name}",
            transcript_kind,
            "production_receipt",
            transcript_path,
            source_manifest,
        )
    )
    for item in items:
        by_id[item["id"]] = item
    lock["episode"] = ctx.episode_id
    lock["generated_at"] = utc_now()
    lock["artifacts"] = list(by_id.values())
    write_json(ctx.artifact_lock_path, lock)
    return ctx.artifact_lock_path


def update_audio_task_status(ctx: EpisodeContext, status_value: str) -> None:
    if not ctx.tasks_path.exists():
        return
    rows = []
    changed = False
    for raw in ctx.tasks_path.read_text(encoding="utf-8").splitlines():
        if not raw.strip():
            continue
        item = json.loads(raw)
        if item.get("gate") == "audio_keep" or item.get("task_id") == f"{ctx.episode_id}-audio-keep":
            if item.get("status") != "keep":
                item["status"] = status_value
                changed = True
        rows.append(item)
    if changed:
        ctx.tasks_path.write_text("\n".join(json.dumps(row, separators=(",", ":")) for row in rows) + "\n", encoding="utf-8")


def write_promote_audio_receipts(ctx: EpisodeContext, validation: dict[str, Any], *, kept: bool) -> None:
    created_at = utc_now()
    package = validation["package"]
    render_settings = package.get("render_settings", {})
    if not isinstance(render_settings, dict):
        render_settings = {}
    render_receipt = {
        "schema_version": 1,
        "created_at": created_at,
        "episode_id": ctx.episode_id,
        "gate": "audio_keep",
        "stage": "longform_audio_render",
        "status": "pass",
        "provider": package.get("provider", ""),
        "model": package.get("model", ""),
        "output_format": render_settings.get("elevenlabs_output_format", ""),
        "source_script_path": safe_rel(ctx.script_path),
        "source_script_sha256": validation["source_script_sha256"],
        "approved_script_hash_only": True,
        "approval_receipt_path": safe_rel(ctx.approval_receipt_path),
        "approval_receipt_sha256": sha256(ctx.approval_receipt_path),
        "preflight_path": safe_rel(ctx.preflight_path),
        "preflight_sha256": sha256(ctx.preflight_path),
        "artifact_root": safe_rel(validation["package_path"].parent),
        "master_audio_path": safe_rel(validation["audio_path"]),
        "master_audio_sha256": validation["audio_sha256"],
        "audio_package_path": safe_rel(validation["package_path"]),
        "audio_package_sha256": validation["package_sha256"],
        "chunk_count": validation["chunk_count"],
        "notes": "Rendered under .artifacts only. Promote-audio prepared this package for audio_keep review.",
    }
    integrity_receipt = {
        "schema_version": 1,
        "created_at": created_at,
        "episode_id": ctx.episode_id,
        "gate": "script_audio_source_integrity",
        "status": "pass",
        "source_script_path": safe_rel(ctx.script_path),
        "source_script_sha256": validation["source_script_sha256"],
        "approval_receipt_path": safe_rel(ctx.approval_receipt_path),
        "approval_script_sha256_reviewed": validation["approval_receipt"].get("script_sha256_reviewed", ""),
        "preflight_path": safe_rel(ctx.preflight_path),
        "preflight_sha256": sha256(ctx.preflight_path),
        "effective_manifest_path": safe_rel(validation["effective_manifest_path"]) if validation["effective_manifest_path"] else "",
        "effective_manifest_sha256": validation["effective_manifest_sha256"],
        "audio_package_path": safe_rel(validation["package_path"]),
        "audio_package_sha256": validation["package_sha256"],
        "master_audio_path": safe_rel(validation["audio_path"]),
        "master_audio_sha256": validation["audio_sha256"],
        "transcript_path": safe_rel(validation["transcript_path"]),
        "transcript_sha256": validation["transcript_sha256"],
        "assertions": {
            "approval_hash_matches_current_script": True,
            "preflight_references_current_script_hash": True,
            "audio_artifacts_under_dot_artifacts": True,
            "no_generated_media_written_to_episode_folder": True,
            "transcript_qa_completed": True,
            "audio_review_passed": kept,
        },
        "chunk_count": validation["chunk_count"],
        "next_gate": "visual_system_plan" if kept else "audio_keep",
    }
    write_json(ctx.episode_dir / "receipts" / "audio-render.json", render_receipt)
    write_json(ctx.episode_dir / "receipts" / "audio-source-integrity.json", integrity_receipt)


def update_state_current_stage(ctx: EpisodeContext, stage: str) -> None:
    state = load_json(ctx.state_path, {})
    if not state:
        return
    state["current_stage"] = stage
    write_json(ctx.state_path, state)


def promote_audio(args: argparse.Namespace) -> int:
    ctx = resolve_episode_context(args.episode_id)
    package_path = resolve_path_token(args.package) if args.package else default_audio_package_path(ctx)
    validation = validate_promotable_audio_package(ctx, package_path)
    gate_status = read_gate_status(ctx.episode_toml_path, "audio_keep", "pending")
    kept = gate_status == "keep"
    if args.dry_run:
        print(f"dry-run ok: {ctx.episode_id} audio package is promotable")
        print(f"package: {safe_rel(validation['package_path'])}")
        print(f"audio: {safe_rel(validation['audio_path'])}")
        print(f"transcript: {safe_rel(validation['transcript_path'])}")
        return 0

    lock_path = update_audio_artifact_lock(ctx, validation, kept=kept)
    write_promote_audio_receipts(ctx, validation, kept=kept)
    if not kept:
        write_gate_status(ctx.episode_toml_path, "audio_keep", "review_ready")
        update_audio_task_status(ctx, "review_ready")
        update_state_current_stage(ctx, "audio_keep")
    print(f"promoted audio package -> {safe_rel(validation['package_path'])}")
    print(f"updated artifacts -> {safe_rel(lock_path)}")
    print("audio_keep remains keep" if kept else "audio_keep -> review_ready")
    return 0


def status(_: argparse.Namespace) -> int:
    print(f"root: {ROOT}")
    git = run(["git", "status", "--short", "--untracked-files=all"], check=False)
    print("git: clean" if not git.stdout.strip() else "git: dirty")
    if git.stdout.strip():
        print(git.stdout.rstrip())
    report = load_json(ROOT / "ops/migration/source-repos.json", {})
    repos = report.get("source_repos", [])
    if repos:
        print(f"source repos: {len(repos)} recorded")
        for repo in repos:
            head = repo.get("head_short", "not-git")
            clean = "clean" if not repo.get("status_short") else "dirty"
            print(f"  {repo['name']}: {head} {clean}")
    artifact_report = load_json(ROOT / "ops/migration/artifact-import-report.json", {})
    if artifact_report:
        print(f"artifacts: {artifact_report.get('count', 0)} files, {artifact_report.get('bytes', 0)} bytes")
    return 0


def find_nested_git() -> list[Path]:
    nested = []
    for current, dirs, _ in os.walk(ROOT):
        current_path = Path(current)
        if current_path == ROOT / ".git":
            dirs[:] = []
            continue
        if ".git" in dirs:
            git_path = current_path / ".git"
            if git_path != ROOT / ".git":
                nested.append(git_path)
            dirs.remove(".git")
        if current_path.name in {"node_modules", ".next", ".artifacts"}:
            dirs[:] = []
    return nested


def find_tracked_unapproved_media() -> list[Path]:
    bad = []
    tracked = run(["git", "ls-files", "-z"], check=False)
    for raw in tracked.stdout.split("\0"):
        if not raw:
            continue
        path = ROOT / raw
        if path.suffix.lower() not in MEDIA_EXTENSIONS:
            continue
        if path in APPROVED_MEDIA_FILES:
            continue
        if any(is_under(path, prefix) for prefix in APPROVED_MEDIA_PREFIXES):
            continue
        bad.append(path)
    return bad


def find_active_legacy_references() -> list[Path]:
    hits = []
    home_prefix = "/Users" + "/mike/"
    legacy_suffix = "_" + "CascadeEffects"
    old_root_needles = [f"{home_prefix}{stem}{legacy_suffix}" for stem in OLD_ROOT_STEMS]
    obsolete_active_needles = [str(ROOT / name) for name in sorted(LEGACY_TOP_LEVEL_DIRS)]
    obsolete_active_needles.append(str(LEGACY_EPISODE_DIR))
    needles = old_root_needles + obsolete_active_needles
    for current, dirs, files in os.walk(ROOT):
        current_path = Path(current)
        if current_path.name in {".git", ".artifacts", "node_modules", ".next", "__pycache__"}:
            dirs[:] = []
            continue
        if any(is_under(current_path, excluded) for excluded in LEGACY_REFERENCE_EXCLUDES):
            dirs[:] = []
            continue
        for name in files:
            path = current_path / name
            if path.suffix.lower() in MEDIA_EXTENSIONS:
                continue
            try:
                text = path.read_text(errors="ignore")
            except OSError:
                continue
            if any(needle in text for needle in needles):
                hits.append(path)
    return hits


def find_legacy_active_dirs() -> list[Path]:
    hits = [ROOT / name for name in sorted(LEGACY_TOP_LEVEL_DIRS) if (ROOT / name).exists()]
    if LEGACY_EPISODE_DIR.exists():
        hits.append(LEGACY_EPISODE_DIR)
    return hits


def find_expired_locks() -> list[Path]:
    expired = []
    now = datetime.now(timezone.utc)
    for lock_path in (ROOT / "ops" / "locks").glob("*.lock.json"):
        data = load_json(lock_path, {})
        raw = str(data.get("lease_expires_at", "")).strip()
        if not raw:
            continue
        try:
            expires_at = datetime.fromisoformat(raw.replace("Z", "+00:00"))
        except ValueError:
            expired.append(lock_path)
            continue
        if expires_at < now:
            expired.append(lock_path)
    return expired


def verify_artifacts() -> list[str]:
    errors = []
    for lock_path in ROOT.glob("**/artifacts.lock.json"):
        data = load_json(lock_path, {})
        for item in data.get("artifacts", []):
            artifact_path = ROOT / item.get("artifact_path", "")
            if not artifact_path.exists():
                errors.append(f"missing artifact: {lock_path}: {item.get('artifact_path')}")
                continue
            expected = item.get("sha256")
            if expected and sha256(artifact_path) != expected:
                errors.append(f"checksum mismatch: {item.get('artifact_path')}")
    return errors


def doctor(_: argparse.Namespace) -> int:
    errors: list[str] = []

    nested = find_nested_git()
    errors.extend(f"nested git repo: {rel(path)}" for path in nested)

    legacy_dirs = find_legacy_active_dirs()
    errors.extend(f"legacy active top-level path remains: {rel(path)}" for path in legacy_dirs)

    media = find_tracked_unapproved_media()
    errors.extend(f"tracked media outside .artifacts or web public assets: {rel(path)}" for path in media[:50])
    if len(media) > 50:
        errors.append(f"tracked media count exceeded display limit: {len(media)}")

    errors.extend(verify_artifacts())
    errors.extend(f"expired or invalid lock: {rel(path)}" for path in find_expired_locks())

    for required in [
        ROOT / "cascade.toml",
        ROOT / "apps/review",
        ROOT / "packages/production-tools",
        ROOT / "packages/media-pipeline",
        ROOT / "episodes/season-02/_template/episode.toml",
        ROOT / "episodes/season-02/_template/tasks.jsonl",
        ROOT / "episodes/season-02/_template/artifacts.lock.json",
        ROOT / "episodes/season-02/backlog.md",
        ROOT / "ops/migration/source-repos.json",
    ]:
        if not required.exists():
            errors.append(f"missing required file: {rel(required)}")

    legacy_hits = find_active_legacy_references()
    if legacy_hits:
        errors.extend(f"legacy reference outside archive/migration: {rel(path)}" for path in legacy_hits[:50])
        if len(legacy_hits) > 50:
            errors.append(f"legacy reference count exceeded display limit: {len(legacy_hits)}")

    if errors:
        print("doctor: FAIL")
        for item in errors:
            print(f"error: {item}")
        return 1

    print("doctor: PASS")
    return 0


def validate(args: argparse.Namespace) -> int:
    return doctor(args)


def new_episode(args: argparse.Namespace) -> int:
    season = args.season
    episode_id = args.episode_id
    title = args.title or episode_id.replace("-", " ").title()
    target = ROOT / "episodes" / season / episode_id
    template = ROOT / "episodes" / season / "_template"
    if not template.exists():
        print(f"missing template: {rel(template)}", file=sys.stderr)
        return 1
    if target.exists() and not args.force:
        print(f"episode already exists: {rel(target)}", file=sys.stderr)
        return 1
    if args.dry_run:
        with tempfile.TemporaryDirectory(prefix="ce-new-episode-") as tmp:
            dry_target = Path(tmp) / episode_id
            materialize_episode(template, dry_target, season, episode_id, title)
        print(f"dry-run ok: would create {rel(target)}")
        return 0
    materialize_episode(template, target, season, episode_id, title, dirs_exist_ok=args.force)
    print(f"created {rel(target)}")
    return 0


def materialize_episode(
    template: Path,
    target: Path,
    season: str,
    episode_id: str,
    title: str,
    *,
    dirs_exist_ok: bool = False,
) -> None:
    shutil.copytree(template, target, dirs_exist_ok=dirs_exist_ok)
    replacements = {
        "__EPISODE_ID__": episode_id,
        "__EPISODE_TITLE__": title,
        "__SEASON__": season,
        "__CREATED_AT__": utc_now(),
    }
    for path in target.rglob("*"):
        if not path.is_file():
            continue
        text = path.read_text()
        for key, value in replacements.items():
            text = text.replace(key, value)
        path.write_text(text)


def claim_task(args: argparse.Namespace) -> int:
    lock_path = ROOT / "ops" / "locks" / f"{args.task_id}.lock.json"
    if lock_path.exists() and not args.force:
        print(f"lock exists: {rel(lock_path)}", file=sys.stderr)
        return 1
    expires = datetime.now(timezone.utc) + timedelta(minutes=args.ttl_minutes)
    write_json(lock_path, {
        "task_id": args.task_id,
        "owner": args.owner,
        "claimed_at": utc_now(),
        "lease_expires_at": expires.replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    })
    print(f"claimed {args.task_id}")
    return 0


def release_task(args: argparse.Namespace) -> int:
    lock_path = ROOT / "ops" / "locks" / f"{args.task_id}.lock.json"
    if lock_path.exists():
        lock_path.unlink()
        print(f"released {args.task_id}")
    else:
        print(f"no lock for {args.task_id}")
    return 0


def import_artifacts(_: argparse.Namespace) -> int:
    report = load_json(ROOT / "ops/migration/artifact-import-report.json", {})
    if not report:
        print("artifact import report is missing", file=sys.stderr)
        return 1
    errors = verify_artifacts()
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 1
    print(f"artifact import verified: {report.get('count', 0)} artifacts")
    return 0


def promote_keep(args: argparse.Namespace) -> int:
    episode_dir = ROOT / "episodes" / args.season / args.episode_id
    lock = load_json(episode_dir / "artifacts.lock.json", {})
    artifacts = lock.get("artifacts", [])
    matches = [item for item in artifacts if item.get("id") == args.artifact_id]
    if not matches:
        print(f"artifact not found: {args.artifact_id}", file=sys.stderr)
        return 1
    receipt = {
        "created_at": utc_now(),
        "episode": args.episode_id,
        "artifact_id": args.artifact_id,
        "disposition": "keep",
        "human_approval_required_for_public_release": True,
        "note": args.note,
    }
    receipt_path = episode_dir / "reviews" / f"keep-{args.artifact_id.replace(':', '-')}.json"
    write_json(receipt_path, receipt)
    print(f"wrote {rel(receipt_path)}")
    return 0


def run_review_command(mapped_args: list[str]) -> int:
    env = os.environ.copy()
    python_paths = [str(ROOT / "apps" / "review"), str(ROOT / "packages" / "production-tools")]
    existing = env.get("PYTHONPATH")
    if existing:
        python_paths.append(existing)
    env["PYTHONPATH"] = os.pathsep.join(python_paths)
    return subprocess.run(
        [sys.executable, "-m", "inbox_app.cli", *mapped_args],
        cwd=ROOT / "apps" / "review",
        env=env,
    ).returncode


def review_server(args: argparse.Namespace) -> int:
    mapped = ["review-server", "--host", args.host, "--port", str(args.port)]
    if args.reload:
        mapped.append("--reload")
    return run_review_command(mapped)


def review_list(args: argparse.Namespace) -> int:
    mapped = ["review-inbox"]
    if args.json:
        mapped.append("--json")
    return run_review_command(mapped)


def review_decision(args: argparse.Namespace, decision: str) -> int:
    mapped = ["review-action", args.episode_id, args.gate_type]
    if args.item_id:
        mapped.append(args.item_id)
    mapped.extend(["--decision", decision])
    if args.reviewer:
        mapped.extend(["--reviewer", args.reviewer])
    if args.notes:
        mapped.extend(["--notes", args.notes])
    for tag in args.tag or []:
        mapped.extend(["--tag", tag])
    return run_review_command(mapped)


def review_approve(args: argparse.Namespace) -> int:
    return review_decision(args, "approve")


def review_reject(args: argparse.Namespace) -> int:
    return review_decision(args, "reject")


def main() -> int:
    parser = argparse.ArgumentParser(prog="ce")
    sub = parser.add_subparsers(dest="command", required=True)
    sub.add_parser("status").set_defaults(func=status)
    sub.add_parser("doctor").set_defaults(func=doctor)
    sub.add_parser("validate").set_defaults(func=validate)
    new = sub.add_parser("new-episode")
    new.add_argument("season")
    new.add_argument("episode_id")
    new.add_argument("--title")
    new.add_argument("--force", action="store_true")
    new.add_argument("--dry-run", action="store_true")
    new.set_defaults(func=new_episode)
    claim = sub.add_parser("claim-task")
    claim.add_argument("task_id")
    claim.add_argument("--owner", required=True)
    claim.add_argument("--ttl-minutes", type=int, default=240)
    claim.add_argument("--force", action="store_true")
    claim.set_defaults(func=claim_task)
    release = sub.add_parser("release-task")
    release.add_argument("task_id")
    release.set_defaults(func=release_task)
    sub.add_parser("import-artifacts").set_defaults(func=import_artifacts)
    audio_keep_parser = sub.add_parser("audio-keep")
    audio_keep_parser.add_argument(
        "audio_command",
        choices=["validate", "cost", "render", "guard", "merge", "qa", "all"],
    )
    audio_keep_parser.add_argument("episode_id", nargs="?")
    audio_keep_parser.set_defaults(func=audio_keep)
    promote_audio_parser = sub.add_parser("promote-audio")
    promote_audio_parser.add_argument("episode_id", nargs="?")
    promote_audio_parser.add_argument("--package")
    promote_audio_parser.add_argument("--dry-run", action="store_true")
    promote_audio_parser.set_defaults(func=promote_audio)
    keep = sub.add_parser("promote-keep")
    keep.add_argument("season")
    keep.add_argument("episode_id")
    keep.add_argument("artifact_id")
    keep.add_argument("--note", default="")
    keep.set_defaults(func=promote_keep)
    review_server_parser = sub.add_parser("review-server")
    review_server_parser.add_argument("--host", default="127.0.0.1")
    review_server_parser.add_argument("--port", type=int, default=8765)
    review_server_parser.add_argument("--reload", action="store_true")
    review_server_parser.set_defaults(func=review_server)
    review_list_parser = sub.add_parser("review-list")
    review_list_parser.add_argument("--json", action="store_true")
    review_list_parser.set_defaults(func=review_list)
    for command, handler in [("review-approve", review_approve), ("review-reject", review_reject)]:
        review_action = sub.add_parser(command)
        review_action.add_argument("episode_id")
        review_action.add_argument("gate_type")
        review_action.add_argument("item_id", nargs="?")
        review_action.add_argument("--reviewer")
        review_action.add_argument("--notes")
        review_action.add_argument("--tag", action="append", default=[])
        review_action.set_defaults(func=handler)
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
