#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import json
import os
import shutil
import subprocess
import sys
import tempfile
import time
from datetime import datetime, timedelta, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
ARTIFACT_ROOT = ROOT / ".artifacts"
MEDIA_EXTENSIONS = {
    ".aiff", ".flac", ".gif", ".jpeg", ".jpg", ".m4a", ".mkv", ".mov", ".mp3", ".mp4",
    ".pdf", ".png", ".raw", ".wav", ".webp",
}
APPROVED_MEDIA_PREFIXES = [
    ROOT / "apps" / "web" / "public",
    ROOT / "apps" / "web" / "brand" / "assets",
]
APPROVED_MEDIA_FILES = {
    ROOT / "apps" / "web" / "app" / "icon.png",
}
LEGACY_REFERENCE_EXCLUDES = [
    ROOT / "archive",
    ROOT / "ops" / "migration",
]
LEGACY_TOP_LEVEL_DIRS = {"agents", "audio", "viz", "inbox", "labs", "channel"}
LEGACY_EPISODE_DIR = ROOT / "episodes" / "season-01"
OLD_ROOT_STEMS = [
    "Agents",
    "Audio",
    "Episodes",
    "Inbox",
    "StyleLab",
    "Viz",
    "Web",
    "FluxLab",
]


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def run(cmd: list[str], cwd: Path = ROOT, check: bool = True) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, cwd=cwd, check=check, text=True, capture_output=True)


def rel(path: Path) -> str:
    return str(path.relative_to(ROOT))


def load_json(path: Path, default):
    if not path.exists():
        return default
    return json.loads(path.read_text())


def write_json(path: Path, data) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2) + "\n")


def sha256(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()


def is_under(path: Path, parent: Path) -> bool:
    try:
        path.relative_to(parent)
        return True
    except ValueError:
        return False


def status(_: argparse.Namespace) -> int:
    print(f"root: {ROOT}")
    git = run(["git", "status", "--short", "--untracked-files=all"], check=False)
    print("git: clean" if not git.stdout.strip() else "git: dirty")
    if git.stdout.strip():
        print(git.stdout.rstrip())
    report = load_json(ROOT / "ops/migration/source-repos.json", {})
    repos = report.get("source_repos", [])
    if repos:
        print(f"source repos: {len(repos)} recorded")
        for repo in repos:
            head = repo.get("head_short", "not-git")
            clean = "clean" if not repo.get("status_short") else "dirty"
            print(f"  {repo['name']}: {head} {clean}")
    artifact_report = load_json(ROOT / "ops/migration/artifact-import-report.json", {})
    if artifact_report:
        print(f"artifacts: {artifact_report.get('count', 0)} files, {artifact_report.get('bytes', 0)} bytes")
    return 0


def find_nested_git() -> list[Path]:
    nested = []
    for current, dirs, _ in os.walk(ROOT):
        current_path = Path(current)
        if current_path == ROOT / ".git":
            dirs[:] = []
            continue
        if ".git" in dirs:
            git_path = current_path / ".git"
            if git_path != ROOT / ".git":
                nested.append(git_path)
            dirs.remove(".git")
        if current_path.name in {"node_modules", ".next", ".artifacts"}:
            dirs[:] = []
    return nested


def find_tracked_unapproved_media() -> list[Path]:
    bad = []
    tracked = run(["git", "ls-files", "-z"], check=False)
    for raw in tracked.stdout.split("\0"):
        if not raw:
            continue
        path = ROOT / raw
        if path.suffix.lower() not in MEDIA_EXTENSIONS:
            continue
        if path in APPROVED_MEDIA_FILES:
            continue
        if any(is_under(path, prefix) for prefix in APPROVED_MEDIA_PREFIXES):
            continue
        bad.append(path)
    return bad


def find_active_legacy_references() -> list[Path]:
    hits = []
    home_prefix = "/Users" + "/mike/"
    legacy_suffix = "_" + "CascadeEffects"
    old_root_needles = [f"{home_prefix}{stem}{legacy_suffix}" for stem in OLD_ROOT_STEMS]
    obsolete_active_needles = [str(ROOT / name) for name in sorted(LEGACY_TOP_LEVEL_DIRS)]
    obsolete_active_needles.append(str(LEGACY_EPISODE_DIR))
    needles = old_root_needles + obsolete_active_needles
    for current, dirs, files in os.walk(ROOT):
        current_path = Path(current)
        if current_path.name in {".git", ".artifacts", "node_modules", ".next", "__pycache__"}:
            dirs[:] = []
            continue
        if any(is_under(current_path, excluded) for excluded in LEGACY_REFERENCE_EXCLUDES):
            dirs[:] = []
            continue
        for name in files:
            path = current_path / name
            if path.suffix.lower() in MEDIA_EXTENSIONS:
                continue
            try:
                text = path.read_text(errors="ignore")
            except OSError:
                continue
            if any(needle in text for needle in needles):
                hits.append(path)
    return hits


def find_legacy_active_dirs() -> list[Path]:
    hits = [ROOT / name for name in sorted(LEGACY_TOP_LEVEL_DIRS) if (ROOT / name).exists()]
    if LEGACY_EPISODE_DIR.exists():
        hits.append(LEGACY_EPISODE_DIR)
    return hits


def find_expired_locks() -> list[Path]:
    expired = []
    now = datetime.now(timezone.utc)
    for lock_path in (ROOT / "ops" / "locks").glob("*.lock.json"):
        data = load_json(lock_path, {})
        raw = str(data.get("lease_expires_at", "")).strip()
        if not raw:
            continue
        try:
            expires_at = datetime.fromisoformat(raw.replace("Z", "+00:00"))
        except ValueError:
            expired.append(lock_path)
            continue
        if expires_at < now:
            expired.append(lock_path)
    return expired


def verify_artifacts() -> list[str]:
    errors = []
    for lock_path in ROOT.glob("**/artifacts.lock.json"):
        data = load_json(lock_path, {})
        for item in data.get("artifacts", []):
            artifact_path = ROOT / item.get("artifact_path", "")
            if not artifact_path.exists():
                errors.append(f"missing artifact: {lock_path}: {item.get('artifact_path')}")
                continue
            expected = item.get("sha256")
            if expected and sha256(artifact_path) != expected:
                errors.append(f"checksum mismatch: {item.get('artifact_path')}")
    return errors


def doctor(_: argparse.Namespace) -> int:
    errors: list[str] = []

    nested = find_nested_git()
    errors.extend(f"nested git repo: {rel(path)}" for path in nested)

    legacy_dirs = find_legacy_active_dirs()
    errors.extend(f"legacy active top-level path remains: {rel(path)}" for path in legacy_dirs)

    media = find_tracked_unapproved_media()
    errors.extend(f"tracked media outside .artifacts or web public assets: {rel(path)}" for path in media[:50])
    if len(media) > 50:
        errors.append(f"tracked media count exceeded display limit: {len(media)}")

    errors.extend(verify_artifacts())
    errors.extend(f"expired or invalid lock: {rel(path)}" for path in find_expired_locks())

    for required in [
        ROOT / "cascade.toml",
        ROOT / "apps/review",
        ROOT / "packages/production-tools",
        ROOT / "packages/media-pipeline",
        ROOT / "episodes/season-02/_template/episode.toml",
        ROOT / "episodes/season-02/_template/tasks.jsonl",
        ROOT / "episodes/season-02/_template/artifacts.lock.json",
        ROOT / "episodes/season-02/backlog.md",
        ROOT / "ops/migration/source-repos.json",
    ]:
        if not required.exists():
            errors.append(f"missing required file: {rel(required)}")

    legacy_hits = find_active_legacy_references()
    if legacy_hits:
        errors.extend(f"legacy reference outside archive/migration: {rel(path)}" for path in legacy_hits[:50])
        if len(legacy_hits) > 50:
            errors.append(f"legacy reference count exceeded display limit: {len(legacy_hits)}")

    if errors:
        print("doctor: FAIL")
        for item in errors:
            print(f"error: {item}")
        return 1

    print("doctor: PASS")
    return 0


def validate(args: argparse.Namespace) -> int:
    return doctor(args)


def new_episode(args: argparse.Namespace) -> int:
    season = args.season
    episode_id = args.episode_id
    title = args.title or episode_id.replace("-", " ").title()
    target = ROOT / "episodes" / season / episode_id
    template = ROOT / "episodes" / season / "_template"
    if not template.exists():
        print(f"missing template: {rel(template)}", file=sys.stderr)
        return 1
    if target.exists() and not args.force:
        print(f"episode already exists: {rel(target)}", file=sys.stderr)
        return 1
    if args.dry_run:
        with tempfile.TemporaryDirectory(prefix="ce-new-episode-") as tmp:
            dry_target = Path(tmp) / episode_id
            materialize_episode(template, dry_target, season, episode_id, title)
        print(f"dry-run ok: would create {rel(target)}")
        return 0
    materialize_episode(template, target, season, episode_id, title, dirs_exist_ok=args.force)
    print(f"created {rel(target)}")
    return 0


def materialize_episode(
    template: Path,
    target: Path,
    season: str,
    episode_id: str,
    title: str,
    *,
    dirs_exist_ok: bool = False,
) -> None:
    shutil.copytree(template, target, dirs_exist_ok=dirs_exist_ok)
    replacements = {
        "__EPISODE_ID__": episode_id,
        "__EPISODE_TITLE__": title,
        "__SEASON__": season,
        "__CREATED_AT__": utc_now(),
    }
    for path in target.rglob("*"):
        if not path.is_file():
            continue
        text = path.read_text()
        for key, value in replacements.items():
            text = text.replace(key, value)
        path.write_text(text)


def claim_task(args: argparse.Namespace) -> int:
    lock_path = ROOT / "ops" / "locks" / f"{args.task_id}.lock.json"
    if lock_path.exists() and not args.force:
        print(f"lock exists: {rel(lock_path)}", file=sys.stderr)
        return 1
    expires = datetime.now(timezone.utc) + timedelta(minutes=args.ttl_minutes)
    write_json(lock_path, {
        "task_id": args.task_id,
        "owner": args.owner,
        "claimed_at": utc_now(),
        "lease_expires_at": expires.replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    })
    print(f"claimed {args.task_id}")
    return 0


def release_task(args: argparse.Namespace) -> int:
    lock_path = ROOT / "ops" / "locks" / f"{args.task_id}.lock.json"
    if lock_path.exists():
        lock_path.unlink()
        print(f"released {args.task_id}")
    else:
        print(f"no lock for {args.task_id}")
    return 0


def import_artifacts(_: argparse.Namespace) -> int:
    report = load_json(ROOT / "ops/migration/artifact-import-report.json", {})
    if not report:
        print("artifact import report is missing", file=sys.stderr)
        return 1
    errors = verify_artifacts()
    if errors:
        for error in errors:
            print(error, file=sys.stderr)
        return 1
    print(f"artifact import verified: {report.get('count', 0)} artifacts")
    return 0


def promote_keep(args: argparse.Namespace) -> int:
    episode_dir = ROOT / "episodes" / args.season / args.episode_id
    lock = load_json(episode_dir / "artifacts.lock.json", {})
    artifacts = lock.get("artifacts", [])
    matches = [item for item in artifacts if item.get("id") == args.artifact_id]
    if not matches:
        print(f"artifact not found: {args.artifact_id}", file=sys.stderr)
        return 1
    receipt = {
        "created_at": utc_now(),
        "episode": args.episode_id,
        "artifact_id": args.artifact_id,
        "disposition": "keep",
        "human_approval_required_for_public_release": True,
        "note": args.note,
    }
    receipt_path = episode_dir / "reviews" / f"keep-{args.artifact_id.replace(':', '-')}.json"
    write_json(receipt_path, receipt)
    print(f"wrote {rel(receipt_path)}")
    return 0


def run_review_command(mapped_args: list[str]) -> int:
    env = os.environ.copy()
    python_paths = [str(ROOT / "apps" / "review"), str(ROOT / "packages" / "production-tools")]
    existing = env.get("PYTHONPATH")
    if existing:
        python_paths.append(existing)
    env["PYTHONPATH"] = os.pathsep.join(python_paths)
    return subprocess.run(
        [sys.executable, "-m", "inbox_app.cli", *mapped_args],
        cwd=ROOT / "apps" / "review",
        env=env,
    ).returncode


def review_server(args: argparse.Namespace) -> int:
    mapped = ["review-server", "--host", args.host, "--port", str(args.port)]
    if args.reload:
        mapped.append("--reload")
    return run_review_command(mapped)


def review_list(args: argparse.Namespace) -> int:
    mapped = ["review-inbox"]
    if args.json:
        mapped.append("--json")
    return run_review_command(mapped)


def review_decision(args: argparse.Namespace, decision: str) -> int:
    mapped = ["review-action", args.episode_id, args.gate_type]
    if args.item_id:
        mapped.append(args.item_id)
    mapped.extend(["--decision", decision])
    if args.reviewer:
        mapped.extend(["--reviewer", args.reviewer])
    if args.notes:
        mapped.extend(["--notes", args.notes])
    for tag in args.tag or []:
        mapped.extend(["--tag", tag])
    return run_review_command(mapped)


def review_approve(args: argparse.Namespace) -> int:
    return review_decision(args, "approve")


def review_reject(args: argparse.Namespace) -> int:
    return review_decision(args, "reject")


def main() -> int:
    parser = argparse.ArgumentParser(prog="ce")
    sub = parser.add_subparsers(dest="command", required=True)
    sub.add_parser("status").set_defaults(func=status)
    sub.add_parser("doctor").set_defaults(func=doctor)
    sub.add_parser("validate").set_defaults(func=validate)
    new = sub.add_parser("new-episode")
    new.add_argument("season")
    new.add_argument("episode_id")
    new.add_argument("--title")
    new.add_argument("--force", action="store_true")
    new.add_argument("--dry-run", action="store_true")
    new.set_defaults(func=new_episode)
    claim = sub.add_parser("claim-task")
    claim.add_argument("task_id")
    claim.add_argument("--owner", required=True)
    claim.add_argument("--ttl-minutes", type=int, default=240)
    claim.add_argument("--force", action="store_true")
    claim.set_defaults(func=claim_task)
    release = sub.add_parser("release-task")
    release.add_argument("task_id")
    release.set_defaults(func=release_task)
    sub.add_parser("import-artifacts").set_defaults(func=import_artifacts)
    keep = sub.add_parser("promote-keep")
    keep.add_argument("season")
    keep.add_argument("episode_id")
    keep.add_argument("artifact_id")
    keep.add_argument("--note", default="")
    keep.set_defaults(func=promote_keep)
    review_server_parser = sub.add_parser("review-server")
    review_server_parser.add_argument("--host", default="127.0.0.1")
    review_server_parser.add_argument("--port", type=int, default=8765)
    review_server_parser.add_argument("--reload", action="store_true")
    review_server_parser.set_defaults(func=review_server)
    review_list_parser = sub.add_parser("review-list")
    review_list_parser.add_argument("--json", action="store_true")
    review_list_parser.set_defaults(func=review_list)
    for command, handler in [("review-approve", review_approve), ("review-reject", review_reject)]:
        review_action = sub.add_parser(command)
        review_action.add_argument("episode_id")
        review_action.add_argument("gate_type")
        review_action.add_argument("item_id", nargs="?")
        review_action.add_argument("--reviewer")
        review_action.add_argument("--notes")
        review_action.add_argument("--tag", action="append", default=[])
        review_action.set_defaults(func=handler)
    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
