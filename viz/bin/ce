#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
AGENTS_ROOT="${CE_AGENTS_ROOT:-/Users/mike/Agents_CascadeEffects}"
ORCHESTRATE_HELPER="${AGENTS_ROOT}/bin/ce-orchestrate"
COMMAND="${1:-help}"

if [ $# -gt 0 ]; then
  shift
fi

usage() {
  cat <<'EOF'
Usage: bin/ce <command> [args]

Commands:
  doctor
  bootstrap
  configure-comfy
  orchestrate
  refs
  workflow
  short
  video
  render
  workbench
  typography
  smoke-image
  smoke-video
  smoke-motion
  experiment-local-motion-quality
  experiment-local-motion-quality-apple-ltx23
  smoke-typography
  smoke-text
  handoff-stage
  handoff-i2v
  help
EOF
}

case "${COMMAND}" in
  workflow)
    exec "${ROOT_DIR}/scripts/workflow.sh" "$@"
    ;;
  refs)
    exec "${ROOT_DIR}/scripts/refs.sh" "$@"
    ;;
  short)
    exec "${ROOT_DIR}/scripts/short.sh" "$@"
    ;;
  video)
    exec "${ROOT_DIR}/scripts/video.sh" "$@"
    ;;
  render)
    exec "${ROOT_DIR}/scripts/render.sh" "$@"
    ;;
  workbench)
    exec "${ROOT_DIR}/scripts/workbench.sh" "$@"
    ;;
  typography)
    exec "${ROOT_DIR}/scripts/typography.sh" "$@"
    ;;
  doctor|bootstrap|configure-comfy|smoke-image|smoke-video|smoke-motion|experiment-local-motion-quality|experiment-local-motion-quality-apple-ltx23|smoke-typography|smoke-text|handoff-stage|handoff-i2v)
    exec "${ROOT_DIR}/scripts/${COMMAND}.sh" "$@"
    ;;
  orchestrate)
    if [ ! -x "${ORCHESTRATE_HELPER}" ]; then
      printf 'Missing orchestrate helper: %s\n' "${ORCHESTRATE_HELPER}" >&2
      exit 66
    fi
    exec "${ORCHESTRATE_HELPER}" "$@"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    printf 'Unknown command: %s\n\n' "${COMMAND}" >&2
    usage >&2
    exit 64
    ;;
esac
