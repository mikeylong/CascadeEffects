{
  "$schema": "./cascade-effects-signal.style-system.schema.json",
  "$description": "Cascade Effects active design tokens for cascade-paper-architectures-ink-lit-v1. The canonical visual direction is ink-lit folded-paper architectural editorial art: deep ink-blue fields, cream paper forms, lavender shadows, cyan vellum glow, restrained coral accents, controlled model lighting, deterministic title policy, and recognizable subject anchors.",
  "$extensions": {
    "com.cascadeeffects": {
      "source": {
        "primarySpec": "Cascade Effects Asset Rule System / cascade-paper-architectures-ink-lit-v1 / May 2026",
        "illustrationContract": "brand/contracts/illustration.contract.json",
        "designSystemContract": "brand/contracts/design-system.contract.json"
      },
      "profile": {
        "id": "cascade-paper-architectures-ink-lit-v1",
        "status": "active",
        "replaces": "cascade-paper-architectures-v1"
      },
      "implementationNotes": {
        "explicitBrandColorsExact": true,
        "supportingSurfaceColorsInferred": false,
        "fontStacksAlignedToRecommendedPairing": true,
        "typeScaleInferred": true,
        "spacingInferred": true,
        "layoutRatiosInferred": true,
        "shadowInferred": true,
        "motionInferred": true
      },
      "guidance": {
        "brandShorthand": "Ink-lit folded paper architectures make hidden system failures visible",
        "positioningLine": "Luminous, model-lit system-failure storytelling built from cream paper structures, ink fields, cyan cascade glow, and recognizable subjects",
        "toneAndMood": [
          "Systemic",
          "Luminous",
          "Editorial",
          "Tactile",
          "Architectural",
          "Clear",
          "Controlled"
        ],
        "thumbnailFormula": "One dominant ink-lit paper-built public subject, clean model shadows, and no generated text inside the episode thumbnail frame",
        "thumbnailTextWordsMin": 2,
        "thumbnailTextWordsMax": 4,
        "thumbnailAccentWordsMax": 0,
        "thumbnailAllCaps": false,
        "thumbnailOneImageOnly": true,
        "evidenceIntegrityRule": "Artifacts must be recognizable system-failure cues and must not imply a source document or logo that is not actually present",
        "imageryVocabulary": [
          "deep ink-blue fields",
          "cream folded paper forms",
          "lavender paper shadows",
          "cyan vellum cascade glow",
          "paper terraces",
          "foam-core surfaces",
          "scored seams",
          "visible cut edges",
          "gouache pigment",
          "controlled model lighting",
          "recognizable public anchors"
        ],
        "motionLanguage": [
          "simple stepped camera moves",
          "subtle parallax",
          "paper-layer reveals",
          "vellum cascade movement",
          "clean title holds",
          "low visual noise"
        ],
        "guardrails": [
          "Do not use generated text inside episode or package source artwork unless an approved title-bearing identity manifest explicitly permits it",
          "Do not use logos, labels, watermarks, or readable marks",
          "Do not use bright/daylight Paper Architectures as active default unless explicitly marked legacy/reference",
          "Do not use dark documentary, noir, smoke, gritty texture, or evidence-board defaults",
          "Do not use dense debris, explosions, horror, gore, or disaster spectacle",
          "Do not use plastic toy gloss, mascot, kawaii, flat icon, or CSS placeholder language"
        ]
      }
    }
  },
