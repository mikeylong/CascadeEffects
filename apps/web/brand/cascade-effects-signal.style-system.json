          "recommendedTextWordsMin": 2,
          "recommendedTextWordsMax": 4,
          "accentWordLimit": 0,
          "oneImageOnly": true,
          "evidenceIntegrityRule": "Use recognizable artifacts as system-failure cues without implying source documents, logos, or readable text that are not present",
          "notes": [
            "Use no generated text inside episode source artwork unless a package manifest explicitly permits approved title-bearing identity art",
            "Keep public anchors large and recognizable at thumbnail size",
