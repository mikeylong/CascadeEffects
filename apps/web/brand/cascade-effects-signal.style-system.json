  "cubicBezier": {
    "standard": {
      "$type": "cubicBezier",
      "$value": [
        0.2,
        0,
        0,
        1
      ]
    },
    "decelerate": {
      "$type": "cubicBezier",
      "$value": [
        0,
        0,
        0.2,
        1
      ]
    },
    "reveal": {
      "$type": "cubicBezier",
      "$value": [
        0.16,
        1,
        0.3,
        1
      ]
    },
    "linear": {
      "$type": "cubicBezier",
      "$value": [
        0,
        0,
        1,
        1
      ]
    }
  },
  "transition": {
    "$description": "Minimal motion defaults for simple console-style camera moves, parallax, and clean callout reveals.",
    "subtleShift": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.fast}",
        "delay": "{duration.instant}",
        "timingFunction": "{cubicBezier.standard}"
      }
    },
    "calloutReveal": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.base}",
        "delay": "{duration.instant}",
        "timingFunction": "{cubicBezier.reveal}"
      }
    },
    "diagramBuild": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.build}",
        "delay": "{duration.instant}",
        "timingFunction": "{cubicBezier.standard}"
      }
