  "cubicBezier": {
    "standard": {
      "$type": "cubicBezier",
      "$value": [
        0.2,
        0.0,
        0.0,
        1.0
      ]
    },
    "decelerate": {
      "$type": "cubicBezier",
      "$value": [
        0.0,
        0.0,
        0.2,
        1.0
      ]
    },
    "emphasis": {
      "$type": "cubicBezier",
      "$value": [
        0.33,
        1.0,
        0.68,
        1.0
      ]
    },
    "linear": {
      "$type": "cubicBezier",
      "$value": [
        0.0,
        0.0,
        1.0,
        1.0
      ]
    }
  },
  "transition": {
    "$description": "Minimal, editorial motion defaults. These are inferred starter values rather than prescriptive brand rules.",
    "reveal": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.base}",
        "delay": "{duration.instant}",
        "timingFunction": "{cubicBezier.standard}"
      }
    },
    "accent": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.fast}",
        "delay": "{duration.instant}",
        "timingFunction": "{cubicBezier.emphasis}"
      }
    },
    "slowPan": {
      "$type": "transition",
      "$value": {
        "duration": "{duration.slowPan}",
        "delay": "{duration.instant}",
        "timingFunction": "{cubicBezier.decelerate}"
      }
    }
  },
