{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Cascade Effects starter design tokens aligned to the March 2026 Brand Spec v1.0. Exact brand colors and the core packaging rules come from the spec. Font families, type scale, spacing, radii, shadows, layout, and motion are practical implementation defaults inferred to make the system usable immediately.",
  "$extensions": {
    "com.cascadeeffects": {
      "source": {
        "primarySpec": "CASCADE EFFECTS BRAND SPEC v1.0 / March 2026"
      },
      "implementationNotes": {
        "brandColorsExact": true,
        "fontFamiliesInferred": true,
        "typeScaleInferred": true,
        "spacingInferred": true,
        "radiiInferred": true,
        "layoutInferred": true,
        "shadowInferred": true,
        "motionInferred": true
      },
      "guidance": {
        "visualPrinciple": "Order disrupted by one element",
        "thumbnailFormula": "Dark field + single lit object + disrupted element",
        "thumbnailTextWordsMin": 3,
        "thumbnailTextWordsMax": 5,
        "accentMixing": "Use one accent color per series; never mix within one frame",
        "backgroundRule": "Prefer dark backgrounds and one dominant focal point"
      }
    }
  },
  "color": {
    "$description": "Primitive brand colors from the approved v1.0 spec plus working alpha variants for UI implementation.",
    "base": {
      "ink": {
        "$type": "color",
        "$value": {
          "colorSpace": "srgb",
          "components": [
            0.102,
            0.102,
            0.1176
          ],
          "alpha": 1.0,
          "hex": "#1A1A1E"
        },
        "$description": "Channel base: dark field."
      },
      "charcoal": {
