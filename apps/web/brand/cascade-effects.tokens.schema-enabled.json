      "$value": {
        "value": 0,
        "unit": "ms"
      }
    },
    "fast": {
      "$type": "duration",
      "$value": {
        "value": 140,
        "unit": "ms"
      }
    },
    "base": {
      "$type": "duration",
      "$value": {
        "value": 240,
        "unit": "ms"
      }
    },
    "slow": {
      "$type": "duration",
      "$value": {
        "value": 400,
        "unit": "ms"
      }
    },
    "slowPan": {
      "$type": "duration",
      "$value": {
        "value": 800,
        "unit": "ms"
      }
    }
